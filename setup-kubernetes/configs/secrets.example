#!/bin/bash
# secrets.example
# Vault seed data for the GitOps platform (apps/, charts/, platform/).
#
# HOW TO USE:
#   1. Copy this file to  configs/secrets.<env>  (e.g. configs/secrets.dev).
#      The configs/ directory is gitignored — secrets never leave the host.
#   2. Fill in every variable below for the target environment. Empty values
#      will be flagged by the seeder.
#   3. Once the seeder is in place (planned: --seed-vault flag), run:
#        sudo ./setup-kubernetes.sh --<env> --seed-vault
#      That step writes every variable below to its Vault KV-v2 path so ESO
#      can sync it into the cluster.
#
# WHAT GETS WRITTEN
#   The seeder iterates VAULT_SCHEMA at the bottom of this file. Each entry
#   maps:   <SHELL_VAR_NAME> | <category> | <name> | <vault-key>
#   For DEPLOY_ENV=dev that becomes a KV-v2 write at:
#     secret/data/dev/<category>/<name>
#   with all of that entry's <vault-key>/value pairs in one Vault entry.
#
#   Two categories are used today:
#     - app     workload apps that ESO reads via SecretStore (mongodb, ...)
#               These names ALSO go into the external-secrets role's
#               bound_service_account_namespaces.
#     - system  control-plane credentials (argocd, kube dashboard, vault).
#               Stored in Vault for reference / automation; NOT read by ESO.
#
#   3-field legacy rows (`<VAR>|<app>|<key>`) still parse — the seeder
#   defaults `category=app`. New rows should use the 4-field form.
#
# SOURCE OF TRUTH
#   Every entry below mirrors a `data:` element in some
#   apps/<name>/values-*.yaml (or values-common.yaml) under
#   `externalSecret.data` or an aliased equivalent. If you add a new app with
#   an ExternalSecret, also add its variable(s) and schema row here.
#
# CONVENTIONS
#   - Single-line values:   VAR="value"
#   - Multi-line values (PEM keys, htpasswd blobs, ssh-keyscan output):
#         VAR=$(cat <<'EOF'
#         …content…
#         EOF
#         )
#     The single-quoted 'EOF' prevents bash from expanding $-references
#     inside the body. The closing `EOF` and `)` must each start at column 0.
#
#   - Generation hints (run BEFORE filling in this file):
#         openssl rand -base64 32          # strong password
#         openssl rand -hex 32             # HMAC / shared secret
#         openssl genrsa -out dkim.pem 2048; cat dkim.pem
#         ssh-keygen -t ed25519 -f id_ed25519 -N ''
#         ssh-keyscan github.com bitbucket.org ssh.dev.azure.com
#         htpasswd -nbB admin '<password>' | sed 's/\$/\$\$/g'   # dbgate

################################################################################
# mongodb — secret/<env>/app/mongodb
# Consumers: apps/mongodb (Bitnami chart auth + mongodb-exporter ESO template
# that composes the connection URI). Also referenced indirectly by dbgate,
# which logs in as the root user.
################################################################################

# Root user password for the replicaset.
MONGODB_ROOT_PASSWORD=""

# Per-user app password (Bitnami's auth.passwords[0]). Currently no
# auth.usernames is set, so this key is required by ESO but never used at
# runtime. Safe to set to the same value as MONGODB_ROOT_PASSWORD.
MONGODB_PASSWORD=""

# Replica-set member auth key. Bitnami requires this whenever
# architecture=replicaset (it is in this platform). Must be 6..1024 chars.
MONGODB_REPLICA_SET_KEY=""

################################################################################
# postgresql — secret/<env>/app/postgresql
# Consumers: apps/postgresql (Bitnami standalone primary + the sidecar
# postgres-exporter, which reuses these credentials). Also referenced
# indirectly by dbgate as the superuser.
################################################################################

# Superuser password (postgres user).
POSTGRES_PASSWORD=""

# App-user password (Bitnami's auth.password). No auth.username is currently
# set, so this is required by ESO but not used at runtime — safe to set to
# the same value as POSTGRES_PASSWORD.
POSTGRESQL_PASSWORD=""

# Used only if architecture later moves to replication. Set to anything
# non-empty; ESO requires the key to be present.
POSTGRESQL_REPLICATION_PASSWORD=""

################################################################################
# postfix — secret/<env>/app/postfix
# Consumers: apps/postfix (DKIM-signs outbound mail; mounted into
# /etc/opendkim/keys/<env>-domain.private). See apps/postfix/POSTFIX-SMTP.md
# for the full DNS setup (A/SPF/DKIM/DMARC + PTR from the hosting provider).
################################################################################

# DKIM private key (PEM, RSA 2048+). Generate with:
#     openssl genrsa -out dkim.pem 2048
# The matching public half goes into a DNS TXT record at:
#     mail._domainkey.mail.<env>.<domain>
POSTFIX_DKIM_PRIVATE_KEY=$(cat <<'EOF'
-----BEGIN RSA PRIVATE KEY-----
…paste PEM here…
-----END RSA PRIVATE KEY-----
EOF
)

################################################################################
# seq — secret/<env>/app/seq
# Consumers: apps/seq (datalust/seq chart — first-run admin + API key).
################################################################################

# First-run admin password (chart's firstRunAdminPasswordSecret.admin-password).
SEQ_ADMIN_PASSWORD=""

# API key for log shippers. Stored alongside the admin password so consuming
# apps can pull it via a distinct secretKey from the same ExternalSecret.
SEQ_API_KEY=""

################################################################################
# dbgate — secret/<env>/app/dbgate
# Consumers: apps/dbgate (unified DB UI at gate.<env>.<domain>).
#
# IMPORTANT
#   DBGATE_MONGODB_PASSWORD must equal MONGODB_ROOT_PASSWORD above, and
#   DBGATE_POSTGRESQL_PASSWORD must equal POSTGRES_PASSWORD above — dbgate
#   logs in as each DB's superuser. The seeder does NOT cross-link these
#   for you (kept explicit so it's visible what's where).
################################################################################

# Plaintext admin password. Stored in Vault as `admin-password` so a
# human can recover it (`vault kv get -field=admin-password secret/<env>/app/dbgate`).
# The htpasswd hash below is what Traefik consumes — bcrypt the plaintext
# with: htpasswd -nbB admin "<plaintext>"
DBGATE_ADMIN_PASSWORD=""

# Traefik BasicAuth htpasswd blob gating gate.<env>.<domain>. Generate with:
#     htpasswd -nbB admin '<password>'
# (Result looks like: admin:$2y$05$...). Needs the `apache2-utils` package.
DBGATE_AUTH=""

# MongoDB root password (mirror of MONGODB_ROOT_PASSWORD).
DBGATE_MONGODB_PASSWORD=""

# PostgreSQL superuser password (mirror of POSTGRES_PASSWORD).
DBGATE_POSTGRESQL_PASSWORD=""

################################################################################
# observability — secret/<env>/app/observability
# Consumers: apps/observability → kube-prometheus-stack → Grafana admin login
# at grafana.<env>.<domain>.
################################################################################

# Grafana admin username. Default is "admin"; override if you prefer a
# non-standard name.
GRAFANA_ADMIN_USER="admin"

# Grafana admin password.
GRAFANA_ADMIN_PASSWORD=""

################################################################################
# image-builder — secret/<env>/app/image-builder
# Consumers: apps/image-builder (Tekton EventListener at build.<env>.<domain>
# + the build-pipeline tasks). Phase A: enabled in DEV only.
################################################################################

# SSH deploy key (PEM). Generate with:
#     ssh-keygen -t ed25519 -f id_imagebuilder -N ''
#     cat id_imagebuilder       # paste below
# Add the matching public key (id_imagebuilder.pub) as a deploy key on every
# source repo you want to build.
IMAGE_BUILDER_ID_RSA=$(cat <<'EOF'
-----BEGIN OPENSSH PRIVATE KEY-----
…paste PEM here…
-----END OPENSSH PRIVATE KEY-----
EOF
)

# Concatenated ssh-keyscan output for every Git provider you build from:
#     ssh-keyscan github.com bitbucket.org ssh.dev.azure.com
# Paste the multi-line output verbatim. Trailing newline is fine.
IMAGE_BUILDER_KNOWN_HOSTS=$(cat <<'EOF'
…paste ssh-keyscan output here…
EOF
)

# Per-provider webhook signing secrets. The SAME value must be:
#     (a) in Vault (this file)         → Tekton Interceptor reads it via ESO
#     (b) in the Git provider's webhook UI as the literal "Secret" / password
# Mismatch produces a 4xx at the listener and no PipelineRun is spawned.
# Generate fresh values with:  openssl rand -hex 32
IMAGE_BUILDER_GITHUB_WEBHOOK_SECRET=""
IMAGE_BUILDER_BITBUCKET_WEBHOOK_SECRET=""

# Azure DevOps Service Hooks use the Basic-auth password field for this.
# Interceptor currently only checks header presence (see
# apps/image-builder/README.md → Security hardening for two fixes).
IMAGE_BUILDER_AZUREDEVOPS_WEBHOOK_SECRET=""

################################################################################
# argocd — secret/<env>/system/argocd
# Argo CD admin login at argo.<env>.<DOMAIN_SUFFIX>. The Helm chart auto-
# generates a random admin password on first install (saved to
# ~/secrets/argocd-<env>.txt). Store it here so it lives alongside the rest
# of the platform credentials; automation / re-installs can re-read it.
################################################################################
ARGOCD_ADMIN_PASSWORD=""

################################################################################
# kube — secret/<env>/system/kube
# Headlamp dashboard token at kube.<env>.<DOMAIN_SUFFIX>. Generated by
# `setup-kubernetes.sh --get-kube-token` (saved to ~/secrets/kube-<env>.txt).
# Paste here after --deploy-kube + --get-kube-token.
################################################################################
KUBE_DASHBOARD_TOKEN=""

################################################################################
# vault — secret/<env>/system/vault
# Generated by `vault operator init` during --deploy-vault (saved to
# ~/secrets/vault-<env>.txt). Paste from that file.
#
# CHICKEN-AND-EGG WARNING: storing Vault's own root token + unseal keys
# INSIDE Vault is convenience-only. If Vault is down/sealed, you can ONLY
# recover with the on-disk file ~/secrets/vault-<env>.txt — the in-Vault
# copies are unreachable until Vault is unsealed by another path. Keep
# ~/secrets/vault-<env>.txt safe.
################################################################################
VAULT_ROOT_TOKEN=""
# All 5 unseal keys, stored as separate Vault entries so automation can read
# any one of them by name. Vault enforces the 3-of-5 quorum at unseal time;
# the numbering here matches the "Unseal Key N" lines in
# ~/secrets/vault-<env>.txt.
VAULT_UNSEAL_KEY_1=""
VAULT_UNSEAL_KEY_2=""
VAULT_UNSEAL_KEY_3=""
VAULT_UNSEAL_KEY_4=""
VAULT_UNSEAL_KEY_5=""

################################################################################
# SCHEMA — DO NOT EDIT unless you also change apps/<name>/values-*.yaml.
#
# Format per line:
#     <SHELL_VAR_NAME>|<category>|<name>|<vault-key>
#     (3-field legacy rows `<VAR>|<name>|<key>` still parse → category=app.)
#
# The seeder writes one Vault entry per (<category>,<name>) tuple, collating
# every row that names that tuple into a single KV-v2 payload at:
#     secret/data/${DEPLOY_ENV}/<category>/<name>
#
# Adding a new app:
#   1. Add the variables in the section above with the rest of its app block
#   2. Add one row per variable below
#   3. Confirm apps/<app>/values-*.yaml's externalSecret.data names match
################################################################################
VAULT_SCHEMA=(
  # mongodb
  "MONGODB_ROOT_PASSWORD|app|mongodb|mongodb-root-password"
  "MONGODB_PASSWORD|app|mongodb|mongodb-password"
  "MONGODB_REPLICA_SET_KEY|app|mongodb|mongodb-replica-set-key"

  # postgresql
  "POSTGRES_PASSWORD|app|postgresql|postgres-password"
  "POSTGRESQL_PASSWORD|app|postgresql|password"
  "POSTGRESQL_REPLICATION_PASSWORD|app|postgresql|replication-password"

  # postfix
  "POSTFIX_DKIM_PRIVATE_KEY|app|postfix|dkim-private-key"

  # seq
  "SEQ_ADMIN_PASSWORD|app|seq|admin-password"
  "SEQ_API_KEY|app|seq|api-key"

  # dbgate
  "DBGATE_AUTH|app|dbgate|auth"
  "DBGATE_ADMIN_PASSWORD|app|dbgate|admin-password"
  "DBGATE_MONGODB_PASSWORD|app|dbgate|mongodb-password"
  "DBGATE_POSTGRESQL_PASSWORD|app|dbgate|postgresql-password"

  # observability
  "GRAFANA_ADMIN_USER|app|observability|admin-user"
  "GRAFANA_ADMIN_PASSWORD|app|observability|grafana-admin-password"

  # image-builder
  "IMAGE_BUILDER_ID_RSA|app|image-builder|id_rsa"
  "IMAGE_BUILDER_KNOWN_HOSTS|app|image-builder|known_hosts"
  "IMAGE_BUILDER_GITHUB_WEBHOOK_SECRET|app|image-builder|github-webhook-secret"
  "IMAGE_BUILDER_BITBUCKET_WEBHOOK_SECRET|app|image-builder|bitbucket-webhook-secret"
  "IMAGE_BUILDER_AZUREDEVOPS_WEBHOOK_SECRET|app|image-builder|azuredevops-webhook-secret"

  # ---- system (control plane — not read by ESO) ----------------------------
  "ARGOCD_ADMIN_PASSWORD|system|argocd|admin-password"
  "KUBE_DASHBOARD_TOKEN|system|kube|dashboard-token"
  "VAULT_ROOT_TOKEN|system|vault|root-token"
  "VAULT_UNSEAL_KEY_1|system|vault|unseal-key-1"
  "VAULT_UNSEAL_KEY_2|system|vault|unseal-key-2"
  "VAULT_UNSEAL_KEY_3|system|vault|unseal-key-3"
  "VAULT_UNSEAL_KEY_4|system|vault|unseal-key-4"
  "VAULT_UNSEAL_KEY_5|system|vault|unseal-key-5"
)

# Apps in the GitOps tree that do NOT need Vault entries (informational —
# the seeder consults VAULT_SCHEMA only, this list is here for completeness):
#   - coredns      (config-only, no secrets)
#   - redis        (auth disabled in this platform)
#   - tekton       (operator install, no app secrets)
