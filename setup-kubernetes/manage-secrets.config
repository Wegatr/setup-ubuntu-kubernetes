#!/bin/bash
# manage-secrets.config
# Files to back up / restore with manage-secrets.sh.
#
# Patterns are RELATIVE to the setup-kubernetes/ directory (the script's
# SCRIPT_DIR), so the encrypted archive restores into the current repo on any
# host regardless of its absolute path.
#
# Covers EVERY secret in the consolidated setup-kubernetes/secrets/ directory:
#   - generated control-plane credentials: vault / argocd / kube / idp-<env>.txt
#   - hand-authored Vault-seed inputs:      secrets.<env>  (+ secrets.<env>.pub.txt)
# The tracked secrets.example template is skipped by manage-secrets.sh.
# config.<env> is NOT a secret and is intentionally excluded from backups.

SECRET_FILES=(
    "secrets/vault-*.txt"
    "secrets/argocd-*.txt"
    "secrets/kube-*.txt"
    "secrets/idp-*.txt"
    "secrets/secrets.*"
)
