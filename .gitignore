# setup-kubernetes/configs/ — keep the *.example templates checked in,
# ignore every real per-env file (config.<env>, secrets.<env>,
# secrets.<env>.pub.txt, etc.).
setup-kubernetes/configs/*
!setup-kubernetes/configs/*.example

# setup-kubernetes/secrets/ — consolidated home for ALL secrets: the
# hand-authored Vault-seed inputs (secrets.<env>, secrets.<env>.pub.txt) AND the
# generated credential files ({vault,argocd,kube,idp}-<env>.txt). Keep ONLY the
# secrets.example template checked in; ignore every real secret.
setup-kubernetes/secrets/*
!setup-kubernetes/secrets/*.example

# Belt-and-suspenders: never commit per-env config / secret / credential files
# even if they show up outside the configs/ or secrets/ directory.
config.dev
config.test
config.prod
secrets.dev
secrets.test
secrets.prod
secrets.dev.pub.txt
secrets.test.pub.txt
secrets.prod.pub.txt
vault-*.txt
argocd-*.txt
kube-*.txt
idp-*.txt

# Helm dependency build artefacts — `helm dependency build` populates
# `charts/` and `Chart.lock` under each app, but ArgoCD does its own
# dependency fetch when rendering, so tracking these would only bloat the
# repo and cause version drift when Chart.yaml is bumped without a re-build.
apps/*/charts/
apps/*/Chart.lock

# NOTE: secrets.enc (the GPG-AES256 encrypted backup produced by
# `manage-secrets.sh --backup`) is intentionally NOT ignored — it is COMMITTED
# to the remote as the off-site, encrypted recovery copy of every secret.

# Temp files
*.tmp
/tmp/
