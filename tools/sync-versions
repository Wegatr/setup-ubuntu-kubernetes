#!/usr/bin/env bash
# tools/sync-versions — propagate platform/versions.yaml into every concrete pin.
#
# platform/versions.yaml is the SINGLE source of truth for component versions.
# Edit a version there, run this script, review `git diff`, commit → ArgoCD
# (apps) / setup-kubernetes (bootstrap) deploy the change.
#
# Why a script: Helm cannot template Chart.yaml dependency versions or the
# bootstrap shell config from a values file, so a pure-Helm "one values file"
# is impossible. This stamps the single source into all three layers:
#   images.*    -> apps/*/values-common.yaml image tags (+ zot appVersion)
#   charts.*    -> apps/*/Chart.yaml dependency versions
#   bootstrap.* -> setup-kubernetes deploy-script defaults + config.example
#
# Edits are surgical (awk/sed touch only the version token), so comments and
# formatting are preserved. yq -i is deliberately NOT used on these files — it
# reflows comment-heavy YAML. yq is used read-only to parse versions.yaml.
set -euo pipefail
cd "$(dirname "$0")/.."
V="platform/versions.yaml"
command -v yq >/dev/null || { echo "ERROR: yq (mikefarah v4) required" >&2; exit 1; }
get() { yq -r "$1" "$V"; }

# --- surgical, format-preserving stampers ------------------------------------
# Set the `version:` line that follows `- name: <dep>` in a Chart.yaml.
set_dep() { # file dep version
  awk -v n="$2" -v v="$3" '
    $0 ~ "^[[:space:]]*-[[:space:]]*name:[[:space:]]*"n"[[:space:]]*$" {f=1}
    f && /^[[:space:]]*version:[[:space:]]/ {sub(/version:.*/, "version: " v); f=0}
    {print}' "$1" >"$1.tmp" && mv "$1.tmp" "$1"
  echo "  chart    $2 = $3   ($1)"
}
# Set the quoted `tag:` line that follows `repository: <repo>` in a values file.
set_tag() { # file repo tag
  awk -v r="$2" -v t="$3" '
    index($0, "repository: " r) {f=1}
    f && /^[[:space:]]*tag:[[:space:]]/ {match($0, /^[[:space:]]*tag:[[:space:]]*/); print substr($0,1,RLENGTH) "\"" t "\""; f=0; next}
    {print}' "$1" >"$1.tmp" && mv "$1.tmp" "$1"
  echo "  image    $2 = $3   ($1)"
}
set_appversion() { sed -i -E "s|^(appVersion: \")[^\"]*\"|\1$2\"|" "$1"; echo "  appVer   $2   ($1)"; }
set_shdef()      { sed -i -E "s|($2:-)[^}]+|\1$3|" "$1";                echo "  default  $2 = $3   ($1)"; }
set_shvar()      { sed -i -E "s|^($2=\")[^\"]*\"|\1$3\"|" "$1";          echo "  shell    $2 = $3   ($1)"; }

echo "== images (official images via charts/deployment) =="
set_tag apps/objectstore/values-common.yaml "dxflrs/garage"                       "$(get .images.garage)"
set_tag apps/objectstore/values-common.yaml "machines/filestash"                  "$(get .images.filestash)"
set_tag apps/registry/values-common.yaml    "ghcr.io/project-zot/zot-linux-amd64" "$(get .images.zot)"
set_appversion apps/registry/Chart.yaml                                           "$(get .images.zot)"
set_tag apps/dbgate/values-common.yaml      "dbgate/dbgate"                       "$(get .images.dbgate)"
set_tag apps/postgresql/values-common.yaml  "postgres"                            "$(get .images.postgres)"
set_tag apps/redis/values-common.yaml       "redis"                               "$(get .images.redis)"
set_tag apps/mongodb/values-common.yaml     "mongo"                               "$(get .images.mongodb)"

echo "== charts (apps/*/Chart.yaml dependencies) =="
set_dep apps/external-secrets/Chart.yaml external-secrets      "$(get '.charts["external-secrets"]')"
set_dep apps/observability/Chart.yaml    kube-prometheus-stack "$(get '.charts["kube-prometheus-stack"]')"
set_dep apps/observability/Chart.yaml    loki                  "$(get .charts.loki)"
set_dep apps/observability/Chart.yaml    tempo                 "$(get .charts.tempo)"
set_dep apps/observability/Chart.yaml    alloy                 "$(get .charts.alloy)"
set_dep apps/postfix/Chart.yaml          mail                  "$(get '.charts["postfix-mail"]')"
set_dep apps/seq/Chart.yaml              seq                   "$(get .charts.seq)"
set_dep apps/postgresql/Chart.yaml prometheus-postgres-exporter "$(get '.charts["prometheus-postgres-exporter"]')"
set_dep apps/mongodb/Chart.yaml    prometheus-mongodb-exporter  "$(get '.charts["prometheus-mongodb-exporter"]')"
set_dep apps/redis/Chart.yaml      prometheus-redis-exporter    "$(get '.charts["prometheus-redis-exporter"]')"

echo "== bootstrap (setup-kubernetes) =="
set_shdef setup-kubernetes/lib/deploy-argocd.sh ARGOCD_CHART_VERSION "$(get .bootstrap.argocd)"
set_shdef setup-kubernetes/lib/deploy-vault.sh  VAULT_CHART_VERSION  "$(get .bootstrap.vault)"
set_shdef setup-kubernetes/lib/deploy-idp.sh    IDP_CHART_VERSION    "$(get .bootstrap.authentik)"
set_shvar setup-kubernetes/configs/config.example MICROK8S_CHANNEL   "$(get .bootstrap.microk8s)"

echo "Done. Review 'git diff', then commit."
